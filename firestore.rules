rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Participants collection: read-only from client (for login lookup).
    // Documents are created via Firebase console or admin scripts only.
    match /participants/{participantId} {
      allow read: if true;  // needed for PIN verification during login
      allow write: if false;
    }

    // Test sessions: append-only with validated shape.
    // No client reads — researchers access data via Firebase console or export script.
    match /test_sessions/{sessionId} {
      allow create: if request.resource.data.participantId is string
                    && request.resource.data.participantId.size() > 0
                    && request.resource.data.testType in ['ccpt', 'nback']
                    && request.resource.data.timestamp is timestamp;
      allow read, update, delete: if false;
    }

    // Consent records: append-only.
    match /consent_records/{recordId} {
      allow create: if request.resource.data.participantId is string
                    && request.resource.data.participantId.size() > 0
                    && request.resource.data.consentVersion is string
                    && request.resource.data.consentTimestamp is timestamp;
      allow read, update, delete: if false;
    }

    // Audit log: append-only, no client reads.
    match /audit_log/{logId} {
      allow create: if request.resource.data.action is string
                    && request.resource.data.action.size() > 0;
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
